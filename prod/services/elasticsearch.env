# elasticsearch service — single-node dev-grade config, no secrets
# (xpack.security is intentionally off; this stack is not internet-exposed
# directly, it's only reached in-network by kibana/fluent-bit/app).
discovery.type=single-node
xpack.security.enabled=false
ES_JAVA_OPTS=-Xms512m -Xmx512m
bootstrap.memory_lock=true
