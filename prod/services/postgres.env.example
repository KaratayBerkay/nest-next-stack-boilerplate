# postgres service — copy to postgres.env (gitignored) and fill in real values.
# Read by docker-compose.yml via `env_file:` on the `postgres` service, and by
# `app`/`migrate` (they build their own DATABASE_URL from the same credentials —
# see app.env.example — so if you change these, update app.env's DATABASE_URL too).
POSTGRES_USER=nest
POSTGRES_PASSWORD=nest
POSTGRES_DB=nest
