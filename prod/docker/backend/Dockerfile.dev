# syntax=docker/dockerfile:1
#
# Development image — single stage, full (dev) dependencies, hot-reload.
#   build:  docker build -f Dockerfile.dev -t nest-boilerplate:dev .
#   run:    docker run --rm -it --network host --env-file .env nest-boilerplate:dev
#   watch:  docker run --rm -it --network host --env-file .env \
#             -v "$PWD/src:/app/src" -v "$PWD/test:/app/test" -v /app/node_modules \
#             nest-boilerplate:dev
# The anonymous `-v /app/node_modules` keeps the image's installed deps from being
# shadowed by a source bind-mount.
FROM node:24-bookworm-slim AS dev

ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
ENV NODE_ENV=development

# Prisma 7's query engine needs openssl + CA certs (Debian slim ships neither by default).
RUN apt-get update \
  && apt-get install -y --no-install-recommends openssl ca-certificates \
  && rm -rf /var/lib/apt/lists/*
RUN corepack enable

WORKDIR /app

# Manifests first so `pnpm install` is cached until deps actually change.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
# Prisma schema/config must exist before install — `postinstall` runs `prisma generate`,
# whose nestgraphql generator writes into ./src.
COPY prisma ./prisma
COPY prisma.config.ts ./
RUN mkdir -p src

# Prisma 7's `prisma generate` (run by postinstall) resolves `env('DATABASE_URL')` from
# prisma.config.ts and fails if unset — pass a throwaway URL for the build (real one comes
# from --env-file at runtime). ARG is not persisted into the image.
ARG DATABASE_URL=postgresql://build:build@localhost:5432/build?schema=public
RUN --mount=type=cache,id=pnpm,target=/pnpm/store pnpm install --frozen-lockfile

# Application source (overlaid by a bind-mount in watch mode).
COPY . .

# HTTP (3000), gRPC (5050), Node inspector (9229).
EXPOSE 3000 5050 9229

STOPSIGNAL SIGTERM

# Longer start-period: `nest start --watch` does a full TS compile before listening.
HEALTHCHECK --interval=30s --timeout=3s --start-period=70s --retries=3 \
  CMD node -e "require('http').get('http://127.0.0.1:'+(process.env.PORT||3000)+'/health',r=>process.exit(r.statusCode===200?0:1)).on('error',()=>process.exit(1))"

CMD ["pnpm", "run", "start:dev"]
