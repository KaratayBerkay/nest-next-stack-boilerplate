# nextjs service (frontend) — copy to nextjs.env (gitignored) and fill in real values.
# Read by docker-compose.yml two ways:
#   - `env_file:` on the `nextjs` service (runtime container env)
#   - `--env-file prod/nextjs.env` passed to `docker compose build nextjs` /
#     `up --build` (NEXT_PUBLIC_* build args are inlined into the client bundle
#     at build time — env_file alone can't reach them, Compose must interpolate
#     ${VAR} while building the image)
# ⚠️  Defaults below are DEV-ONLY — never use in production.
#
# Important: because NEXT_PUBLIC_* vars are inlined at `next build` time, not
# read at container start, changing any of them below requires
#   docker compose build nextjs && docker compose up -d nextjs
# — a plain restart keeps serving the stale baked-in values.

# ---- Runtime (container env) ----
NODE_ENV=production
LOG_LEVEL=info
PORT=3100
HOSTNAME=0.0.0.0
# Internal backend origin (server-side fetches, not browser-reachable)
APP_URL=http://app:3000
MINIO_URL=http://minio:9000
# Must match app.env's COOKIE_DOMAIN.
COOKIE_DOMAIN=
# Must match app.env's KAFKA_BROKER.
KAFKA_BROKER=disabled

# ---- Build args + runtime (browser-reachable — same values, used both ways) ----
# Browser-reachable frontend origin.
NEXT_PUBLIC_APP_URL=http://localhost:3100
# Browser-reachable realtime WebSocket URL (single /ws endpoint on the backend).
NEXT_PUBLIC_REALTIME_WS_URL=ws://localhost:3000/ws
# Browser-reachable file/object-storage origin.
NEXT_PUBLIC_MINIO_PUBLIC_URL=http://localhost:9000
# Must match app.env's VAPID_PUBLIC_KEY — same keypair, both sides.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
