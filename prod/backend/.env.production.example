# Production env template. Copy to `.env.production` (gitignored) and fill with REAL values.
#   docker run --env-file .env.production ...
# Generate secrets with: openssl rand -hex 32

# ---- App ----
NODE_ENV=production
PORT=3000
# Pino log level: trace|debug|info|warn|error|fatal
LOG_LEVEL=info
# Optional: file sink for Fluent Bit → ELK pipeline (set path writable by the container)
# LOG_FILE=logs/app.log

# ---- PostgreSQL (Prisma) ----
# In prod, point at your managed DB / compose service host (not localhost).
DATABASE_URL=postgresql://USER:PASSWORD@db-host:5432/nest?schema=public&sslmode=require

# ---- Redis (cache, BullMQ, microservices) ----
REDIS_HOST=redis-host
REDIS_PORT=6379
REDIS_URL=redis://redis-host:6379

# ---- Auth (REQUIRED — generate strong values, never reuse the dev ones) ----
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=30d
# 32-byte key (64 hex chars) for AES-256-GCM encryption of MFA TOTP secrets
ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32
# Public base URL of this backend (OAuth callbacks)
APP_URL=https://api.example.com
# Public frontend URL (email-confirmation links, OAuth error redirects)
FRONTEND_URL=https://app.example.com

# ---- Web security (cookies / CSRF) — REQUIRED, generate with openssl rand -hex 32 ----
COOKIE_SECRET=CHANGE_ME_openssl_rand_hex_32
CSRF_SECRET=CHANGE_ME_openssl_rand_hex_32
# Cookie domain for subdomain sharing. Set to your root domain (e.g. ".eys.gen.tr")
# so auth cookies reach all subdomains. Must match the frontend's COOKIE_DOMAIN.
# Leave empty for host-only cookies.
COOKIE_DOMAIN=.eys.gen.tr
# SameSite: 'lax' (default) for same-site SSR; 'none' (requires Secure) for cross-site.
COOKIE_SAMESITE=lax

# ---- Web Push (VAPID) ----
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=CHANGE_ME
VAPID_PRIVATE_KEY=CHANGE_ME
VAPID_SUBJECT=mailto:admin@example.com

# ---- Outbox relay ----
OUTBOX_POLL_MS=2000

# ---- gRPC (internal service-to-service transport) ----
# Bind to 0.0.0.0 inside the container; expose only on the internal network.
GRPC_URL=0.0.0.0:5050

# ---- Logging backend: Elasticsearch + Kibana (compose profile: logging) ----
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_PORT=9200
KIBANA_PORT=5601

# ---- Kafka (compose --profile kafka) ----
KAFKA_BROKER=localhost:9092
# Frontend event consumer (Kafka → ES). Set false to disable while keeping code in place.
FRONTEND_EVENTS_CONSUMER_ENABLED=false
