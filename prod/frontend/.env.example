# Copy to .env.local and adjust. .env* is gitignored except this example file.

# --- Server-only (never sent to the browser) ---
PORT=3000
APP_URL=http://localhost:3001

# Kafka broker for frontend event logging (compose --profile kafka)
KAFKA_BROKER=localhost:9092

# Cookie domain for subdomain sharing. Set to your root domain (e.g. ".eys.gen.tr")
# so auth cookies reach all subdomains (app.eys.gen.tr, api.eys.gen.tr, ...).
# Leave empty for host-only cookies (single origin).
# Required in production/staging for cross-subdomain cookie sharing (e.g. app → api).
# Must match the backend's COOKIE_DOMAIN. Leave empty on localhost (host-only).
COOKIE_DOMAIN=.eys.gen.tr
COOKIE_SAMESITE=lax

# OAuth client IDs/secrets live in the NestJS backend .env (auth/oauth controller).
# Configure them there, not here.

# --- Client (inlined into the browser bundle) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000
NEXT_PUBLIC_MSG_WS_URL=ws://localhost:3003
# Web Push — must match the backend's VAPID_PUBLIC_KEY. Build-time variable.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
