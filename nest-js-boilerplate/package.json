  "scripts": {
    "build": "nest build",
    "build:swc": "nest build -b swc",
    "fallow-check": "fallow audit --ci --fail-on-issues",
    "fallow-fix": "fallow fix --yes",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:cli-plugin": "jest --config ./test/jest-cli-plugin.json",
    "test:openapi-plugin": "jest --config ./test/jest-openapi-plugin.json",
    "test:lazy-loading": "jest --config ./test/jest-lazy-loading.json",
    "test:brokers": "jest --config ./test/jest-brokers.json",
    "test:swc": "jest --config ./test/jest-swc.json",
    "test:orms": "jest --config ./test/jest-orms.json",
    "generate": "prisma generate",
    "postinstall": "prisma generate",
    "prebuild": "prisma generate && pnpm fallow-check",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "load:setup": "node test/load-test/setup.mjs",
    "load:run": "k6 run test/load-test/ws-chat-load.js",
    "load:test": "pnpm load:setup && pnpm load:run"
  },
