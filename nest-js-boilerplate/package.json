  "jest": {
    "moduleFileExtensions": [
      "js",
      "mjs",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "lazy-loading.spec.ts"
    ],
    "transform": {
      "^.+\\.m?[tj]s$": [
        "ts-jest",
        {
          "isolatedModules": true,
          "tsconfig": {
            "allowJs": true
          }
        }
      ]
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!.*(prisma-graphql-type-decimal|otplib|@otplib|@scure|@noble))"
    ],
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/@generated/**",
      "!**/*.module.ts",
      "!**/main.ts",
      "!**/*.e2e-spec.ts",
      "!**/test/**"
    ],
    "coverageDirectory": "../coverage",
    "coverageThreshold": {
      "global": {
        "statements": 55,
        "branches": 40,
        "functions": 45,
        "lines": 55
      }
    },
    "testEnvironment": "node"
  }
