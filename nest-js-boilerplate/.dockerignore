# Build-context excludes — keep images lean and secret-free.
# Anything here is invisible to `docker build` for both Dockerfile.dev and Dockerfile.prod.

# Installed/compiled artifacts (re-created inside the image)
node_modules
dist
build
coverage
.nyc_output

# VCS / tooling / docs (not needed at build or run time)
.git
.gitignore
.dockerignore
Dockerfile*
.claude
.vscode
.idea
docs
*.md
*.txt
*.log

# Secrets — NEVER bake env files into an image. Pass them at runtime (--env-file / -e).
.env
.env.*

# Generated by `prisma generate` (prebuild) and at runtime — the builder regenerates these.
/src/@generated
/src/schema.gql
prisma/*.db
