// ============================================================================
// Prisma schema — rich domain model for exercising NestJS + GraphQL + Postgres.
//
// Senior-engineer conventions:
//   * Every primary key is a UUID (uuidv7 — time-ordered for index locality),
//     stored as native Postgres `uuid` (@db.Uuid). NO integer PKs anywhere.
//   * All timestamps are timestamptz; created/updated on every mutable entity.
//   * Soft-delete (deletedAt) on user-facing aggregates.
//   * Money is Decimal(@db.Decimal) — never float.
//   * GraphQL input validations are AUTO-GENERATED from `/// @Validator.*` comments.
//   * Observability: domain changes write an OutboxEvent in the same transaction;
//     a separate worker relays those to a task broker (RabbitMQ/Kafka/Redis) which
//     fans them out to AuditLog (Postgres, ES-exportable) and/or Elasticsearch.
//     Request handlers never persist logs inline. See docs/research.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

generator nestgraphql {
  provider               = "prisma-nestjs-graphql"
  output                 = "../src/@generated"
  fields_Validator_from  = "class-validator"
  fields_Validator_input = true
  purgeOutput            = true
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------
enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  DEACTIVATED
  BANNED
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
  SUPERADMIN
}

enum SubscriptionTier {
  FREE
  BASIC
  MEDIUM
  PREMIUM
}

enum AuthProviderType {
  CREDENTIALS
  GOOGLE
  GITHUB
  APPLE
  FACEBOOK
  MICROSOFT
  GITLAB
  TWITTER
  LINKEDIN
  HUGGING_FACE
  TWITCH
}

enum MfaMethod {
  TOTP
  WEBAUTHN
  SMS
  EMAIL
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  MAGIC_LINK
  PHONE_VERIFICATION
  ORG_INVITATION
  MFA_CHALLENGE
}

enum DeviceType {
  WEB
  MOBILE_IOS
  MOBILE_ANDROID
  DESKTOP
  API
  CLI
}

enum EmailStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  OPENED
  BOUNCED
  FAILED
  COMPLAINED
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
  BILLING
  GUEST
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  LEFT
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  LOWEST
  LOW
  MEDIUM
  HIGH
  HIGHEST
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ReactionType {
  LIKE
  LOVE
  LAUGH
  WOW
  SAD
  ANGRY
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
}

enum NotificationType {
  MENTION
  COMMENT
  REACTION
  FOLLOW
  FRIEND_REQUEST
  POST
  SYSTEM
  BILLING
  SECURITY
}

enum WalletTxnType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  REFUND
  FEE
  ADJUSTMENT
}

enum WalletTxnStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum LogLevel {
  TRACE
  DEBUG
  INFO
  WARN
  ERROR
  FATAL
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  LOGIN_FAILED
  SIGNUP
  EMAIL_VERIFIED
  PASSWORD_CHANGED
  MFA_ENABLED
  MFA_DISABLED
  ROLE_CHANGED
  PERMISSION_GRANTED
  PERMISSION_REVOKED
  EXPORT
  IMPORT
  API_KEY_CREATED
  API_KEY_REVOKED
}

enum OutboxStatus {
  PENDING
  PUBLISHING
  PUBLISHED
  FAILED
  DEAD_LETTER
}

// ---------------------------------------------------------------------------
// Identity & Auth
// ---------------------------------------------------------------------------
model User {
  id String @id @default(uuid(7)) @db.Uuid

  /// @Validator.IsEmail()
  email           String    @unique
  emailVerifiedAt DateTime? @db.Timestamptz(6)

  /// @Validator.IsOptional()
  /// @Validator.MinLength(3)
  /// @Validator.MaxLength(30)
  username String? @unique

  /// @Validator.IsOptional()
  /// @Validator.MaxLength(80)
  name String?

  // credentials auth (null for social-only users)
  /// @HideField()
  passwordHash  String?
  passwordSetAt DateTime? @db.Timestamptz(6)

  status           UserStatus       @default(PENDING_VERIFICATION)
  role             UserRole         @default(USER)
  subscriptionTier SubscriptionTier @default(FREE)

  /// @HideField()
  stripeCustomerId       String?   @unique
  /// @HideField()
  stripeSubscriptionId   String?
  subscriptionPeriodStart DateTime? @db.Timestamptz(6)
  subscriptionPeriodEnd   DateTime? @db.Timestamptz(6)
  cancelAtPeriodEnd      Boolean   @default(false)

  avatarUrl       String?
  bio             String?   @db.Text
  birthDate       DateTime? @db.Date
  quietHoursStart DateTime? @db.Time(6)

  locale   String @default("en")
  timezone String @default("UTC")

  /// @Validator.IsOptional()
  /// @Validator.IsPhoneNumber()
  phoneNumber   String?  @unique
  phoneVerified Boolean  @default(false)

  mfaEnabled Boolean @default(false)

  lastLoginAt      DateTime? @db.Timestamptz(6)
  /// @HideField()
  lastLoginIp      String?   @db.Inet
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime? @db.Timestamptz(6)

  reputation  BigInt   @default(0)
  interests   String[] @default([])
  metadata    Json?    @db.JsonB
  preferences Json?    @db.JsonB

  // self-relation: referral graph
  referredById String? @db.Uuid
  referredBy   User?   @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals    User[]  @relation("UserReferrals")

  // auth
  accounts    Account[]
  devices     Device[]
  mfaFactors  MfaFactor[]
  backupCodes MfaBackupCode[]
  tokens      VerificationToken[]
  emails      EmailMessage[]

  // org / collaboration
  ownedOrganizations Organization[] @relation("OrgOwner")
  memberships        Membership[]   @relation("MembershipUser")
  sentInvites        Membership[]   @relation("MembershipInviter")
  teamMemberships    TeamMember[]
  ledProjects        Project[]      @relation("ProjectLead")
  createdProjects    Project[]      @relation("ProjectCreator")
  assignedTasks      Task[]         @relation("TaskAssignee")
  reportedTasks      Task[]         @relation("TaskReporter")
  createdTasks       Task[]         @relation("TaskCreator")

  // content
  posts     Post[]     @relation("PostAuthor")
  comments  Comment[]  @relation("CommentAuthor")
  reactions Reaction[]

  // social graph (multiple FKs back to User)
  following      Follow[]       @relation("Follower")
  followers      Follow[]       @relation("Following")
  sentFriendReqs Friendship[]   @relation("FriendshipRequester")
  recvFriendReqs Friendship[]   @relation("FriendshipAddressee")
  sentMessages   Message[]      @relation("MessageSender")
  recvMessages   Message[]      @relation("MessageRecipient")
  roomMessages   RoomMessage[]  @relation("RoomMessageSender")
  notifications     Notification[]      @relation("NotificationRecipient")
  triggered         Notification[]      @relation("NotificationActor")
  pushSubscriptions PushSubscription[]

  // money
  wallets Wallet[]

  // billing
  billingAddress BillingAddress?

  // API keys
  apiKeys ApiKey[]

  // observability
  auditLogs AuditLog[] @relation("AuditActor")

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  @@index([status])
  @@index([role])
  @@index([subscriptionTier])
  @@index([referredById])
  @@index([createdAt])
}

model Account {
  id                String           @id @default(uuid(7)) @db.Uuid
  userId            String           @db.Uuid
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              AuthProviderType
  provider          String
  providerAccountId String
  accessToken       String?          @db.Text
  refreshToken      String?          @db.Text
  idToken           String?          @db.Text
  tokenType         String?
  scopes            String[]         @default([])
  expiresAt         DateTime?        @db.Timestamptz(6)
  createdAt         DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime         @updatedAt @db.Timestamptz(6)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Device {
  id          String     @id @default(uuid(7)) @db.Uuid
  userId      String     @db.Uuid
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String?
  /** Cryptographically-random, ≥90-char token stored in the device_token cookie. */
  token       String     @unique
  type        DeviceType @default(WEB)
  ip          String?    @db.Inet
  fingerprint String?
  trusted     Boolean    @default(false)
  lastSeenAt  DateTime?  @db.Timestamptz(6)
  createdAt   DateTime   @default(now()) @db.Timestamptz(6)

  @@index([userId])
}

model PushSubscription {
  id        String   @id @default(uuid(7)) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([userId])
}

model MfaFactor {
  id           String    @id @default(uuid(7)) @db.Uuid
  userId       String    @db.Uuid
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  method       MfaMethod
  label        String?
  secret       Bytes? // encrypted TOTP secret
  credentialId Bytes? // WebAuthn credential id
  publicKey    Bytes? // WebAuthn public key
  counter      BigInt? // WebAuthn signature counter
  transports   String[]  @default([])
  verifiedAt   DateTime? @db.Timestamptz(6)
  lastUsedAt   DateTime? @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)

  @@unique([userId, method, label])
  @@index([userId])
}

model MfaBackupCode {
  id        String    @id @default(uuid(7)) @db.Uuid
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  usedAt    DateTime? @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)

  @@index([userId])
}

model VerificationToken {
  id         String    @id @default(uuid(7)) @db.Uuid
  userId     String?   @db.Uuid
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       TokenType
  tokenHash  String    @unique
  identifier String?
  metadata   Json?     @db.JsonB
  expiresAt  DateTime  @db.Timestamptz(6)
  consumedAt DateTime? @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @db.Timestamptz(6)

  @@index([userId, type])
  @@index([identifier])
}

model EmailMessage {
  id     String  @id @default(uuid(7)) @db.Uuid
  userId String? @db.Uuid
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  /// @Validator.IsEmail()
  to                String
  from              String?
  subject           String
  template          String
  variables         Json?       @db.JsonB
  status            EmailStatus @default(QUEUED)
  provider          String?
  providerMessageId String?
  attempts          Int         @default(0)
  lastError         String?     @db.Text
  scheduledAt       DateTime?   @db.Timestamptz(6)
  sentAt            DateTime?   @db.Timestamptz(6)
  createdAt         DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime    @updatedAt @db.Timestamptz(6)

  @@index([status, scheduledAt])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Organizations & Teams
// ---------------------------------------------------------------------------
model Organization {
  id String @id @default(uuid(7)) @db.Uuid

  /// @Validator.MinLength(2)
  name              String
  slug              String       @unique
  ownerId           String       @db.Uuid
  owner             User         @relation("OrgOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  plan              String       @default("free")
  seatLimit         Int          @default(5)
  storageQuotaBytes BigInt       @default(1073741824)
  allowedDomains    String[]     @default([])
  settings          Json?        @db.JsonB
  memberships       Membership[]
  teams             Team[]
  projects          Project[]
  auditLogs         AuditLog[]
  createdAt         DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime     @updatedAt @db.Timestamptz(6)
  deletedAt         DateTime?    @db.Timestamptz(6)

  @@index([ownerId])
}

model Membership {
  id             String       @id @default(uuid(7)) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String       @db.Uuid
  user           User         @relation("MembershipUser", fields: [userId], references: [id], onDelete: Cascade)
  // second FK to User (multiple FKs to the same table)
  invitedById    String?          @db.Uuid
  invitedBy      User?            @relation("MembershipInviter", fields: [invitedById], references: [id], onDelete: SetNull)
  role           OrgRole          @default(MEMBER)
  status         MembershipStatus @default(ACTIVE)
  joinedAt       DateTime?        @db.Timestamptz(6)
  createdAt      DateTime         @default(now()) @db.Timestamptz(6)

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([invitedById])
}

model Team {
  id             String       @id @default(uuid(7)) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  // self-relation: team hierarchy
  parentTeamId   String?      @db.Uuid
  parentTeam     Team?        @relation("TeamHierarchy", fields: [parentTeamId], references: [id], onDelete: SetNull)
  childTeams     Team[]       @relation("TeamHierarchy")
  members        TeamMember[]
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)

  @@unique([organizationId, name])
  @@index([parentTeamId])
}

model TeamMember {
  id       String   @id @default(uuid(7)) @db.Uuid
  teamId   String   @db.Uuid
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId   String   @db.Uuid
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isLead   Boolean  @default(false)
  joinedAt DateTime @default(now()) @db.Timestamptz(6)

  @@unique([teamId, userId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Projects & Tasks  (3 FKs to User; self-referencing tasks; Decimals to aggregate)
// ---------------------------------------------------------------------------
model Project {
  id             String        @id @default(uuid(7)) @db.Uuid
  organizationId String        @db.Uuid
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  key            String
  description    String?       @db.Text
  status         ProjectStatus @default(PLANNING)
  leadId         String?       @db.Uuid
  lead           User?         @relation("ProjectLead", fields: [leadId], references: [id], onDelete: SetNull)
  createdById    String        @db.Uuid
  createdBy      User          @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: Restrict)
  budget         Decimal?      @db.Decimal(14, 2)
  startDate      DateTime?     @db.Date
  dueDate        DateTime?     @db.Date
  tags           String[]      @default([])
  tasks          Task[]
  createdAt      DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @db.Timestamptz(6)

  @@unique([organizationId, key])
  @@index([leadId])
  @@index([createdById])
}

model Task {
  id        String  @id @default(uuid(7)) @db.Uuid
  projectId String  @db.Uuid
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// @Validator.MinLength(1)
  /// @Validator.MaxLength(200)
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(BACKLOG)
  priority    TaskPriority @default(MEDIUM)

  // three FKs to User: assignee / reporter / creator
  assigneeId  String? @db.Uuid
  assignee    User?   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporterId  String? @db.Uuid
  reporter    User?   @relation("TaskReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  createdById String  @db.Uuid
  createdBy   User    @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Restrict)

  // self-relation: subtasks
  parentTaskId String? @db.Uuid
  parentTask   Task?   @relation("TaskHierarchy", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks     Task[]  @relation("TaskHierarchy")

  estimateHours Decimal?  @db.Decimal(6, 2)
  loggedHours   Decimal   @default(0) @db.Decimal(6, 2)
  storyPoints   Int?
  position      Float     @default(0)
  labels        String[]  @default([])
  dueDate       DateTime? @db.Timestamptz(6)
  completedAt   DateTime? @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(6)

  @@index([projectId, status])
  @@index([assigneeId])
  @@index([reporterId])
  @@index([createdById])
  @@index([parentTaskId])
}

// ---------------------------------------------------------------------------
// Content  (implicit m2m Post<->Tag; self-ref Category & Comment; aggregates)
// ---------------------------------------------------------------------------
model Category {
  id        String     @id @default(uuid(7)) @db.Uuid
  name      String
  slug      String     @unique
  parentId  String?    @db.Uuid
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("CategoryTree")
  posts     Post[]
  createdAt DateTime   @default(now()) @db.Timestamptz(6)

  @@index([parentId])
}

model Tag {
  id    String @id @default(uuid(7)) @db.Uuid
  name  String @unique
  posts Post[]
}

model Post {
  id         String    @id @default(uuid(7)) @db.Uuid
  authorId   String    @db.Uuid
  author     User      @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  categoryId String?   @db.Uuid
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  /// @Validator.MinLength(3)
  /// @Validator.MaxLength(200)
  title       String
  slug        String     @unique
  excerpt     String?    @db.Text
  content     String     @db.Text
  coverImage  Bytes?
  imageUrl    String?
  status      PostStatus @default(DRAFT)
  viewCount   Int        @default(0)
  score       Float      @default(0)
  metadata    Json?      @db.JsonB
  tags        Tag[]
  comments    Comment[]
  reactions   Reaction[]
  publishedAt DateTime?  @db.Timestamptz(6)
  createdAt   DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime?  @db.Timestamptz(6)

  @@index([authorId])
  @@index([status, publishedAt])
  @@index([categoryId])
}

model Comment {
  id       String  @id @default(uuid(7)) @db.Uuid
  postId   String  @db.Uuid
  post     Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId String  @db.Uuid
  author   User    @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  // self-relation: threaded replies
  parentId String? @db.Uuid
  parent   Comment? @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentThread")

  body      String     @db.Text
  imageUrl  String?
  reactions Reaction[]
  createdAt DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt DateTime   @updatedAt @db.Timestamptz(6)
  deletedAt DateTime?  @db.Timestamptz(6)

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
}

model Reaction {
  id        String       @id @default(uuid(7)) @db.Uuid
  userId    String       @db.Uuid
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String?      @db.Uuid
  post      Post?        @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId String?      @db.Uuid
  comment   Comment?     @relation(fields: [commentId], references: [id], onDelete: Cascade)
  type      ReactionType
  createdAt DateTime     @default(now()) @db.Timestamptz(6)

  @@unique([userId, postId, commentId])
  @@index([postId])
  @@index([commentId])
  @@index([userId, type])
}

// ---------------------------------------------------------------------------
// Social graph  (every model here holds 2 FKs to User)
// ---------------------------------------------------------------------------
model Follow {
  id          String   @id @default(uuid(7)) @db.Uuid
  followerId  String   @db.Uuid
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String   @db.Uuid
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  @@unique([followerId, followingId])
  @@index([followingId])
  @@index([followerId, createdAt])
}

model Friendship {
  id          String           @id @default(uuid(7)) @db.Uuid
  requesterId String           @db.Uuid
  requester   User             @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addresseeId String           @db.Uuid
  addressee   User             @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime         @updatedAt @db.Timestamptz(6)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
}

model Message {
  id          String    @id @default(uuid(7)) @db.Uuid
  senderId    String    @db.Uuid
  sender      User      @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId String    @db.Uuid
  recipient   User      @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  body        String    @db.Text
  deliveredAt DateTime? @db.Timestamptz(6)
  readAt      DateTime? @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)

  @@index([senderId, recipientId])
  @@index([recipientId, readAt])
}

model RoomMessage {
  id        String   @id @default(uuid(7)) @db.Uuid
  roomId    String
  senderId  String   @db.Uuid
  sender    User     @relation("RoomMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([roomId, createdAt])
}

model Notification {
  id      String           @id @default(uuid(7)) @db.Uuid
  userId  String           @db.Uuid
  user    User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actorId String?          @db.Uuid
  actor   User?            @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  type    NotificationType
  title   String
  body    String?          @db.Text
  payload Json?            @db.JsonB
  readAt  DateTime?        @db.Timestamptz(6)
  createdAt DateTime       @default(now()) @db.Timestamptz(6)

  @@index([userId, readAt])
  @@index([userId, createdAt(sort: Desc)])
  @@index([actorId])
}

// ---------------------------------------------------------------------------
// Money  (Decimal; two FKs to the SAME table — Wallet)
// ---------------------------------------------------------------------------
model Wallet {
  id        String  @id @default(uuid(7)) @db.Uuid
  userId    String  @db.Uuid
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency  String  @default("USD")
  balance   Decimal @default(0) @db.Decimal(18, 4)
  isPrimary Boolean @default(false)

  outgoing  WalletTransaction[] @relation("TransferFrom")
  incoming  WalletTransaction[] @relation("TransferTo")
  createdAt DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt DateTime            @updatedAt @db.Timestamptz(6)

  @@unique([userId, currency])
}

model WalletTransaction {
  id           String  @id @default(uuid(7)) @db.Uuid
  // two FKs to the same table (Wallet)
  fromWalletId String? @db.Uuid
  fromWallet   Wallet? @relation("TransferFrom", fields: [fromWalletId], references: [id], onDelete: SetNull)
  toWalletId   String? @db.Uuid
  toWallet     Wallet? @relation("TransferTo", fields: [toWalletId], references: [id], onDelete: SetNull)

  type           WalletTxnType
  status         WalletTxnStatus @default(PENDING)
  amount         Decimal         @db.Decimal(18, 4)
  currency       String          @default("USD")
  feeAmount      Decimal         @default(0) @db.Decimal(18, 4)
  idempotencyKey        String    @unique
  reference             String?
  stripePaymentIntentId String?
  stripeInvoiceUrl      String?
  metadata              Json?     @db.JsonB
  postedAt              DateTime? @db.Timestamptz(6)
  createdAt      DateTime        @default(now()) @db.Timestamptz(6)

  @@index([fromWalletId])
  @@index([toWalletId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// API Keys — programmatic access to the API
// ---------------------------------------------------------------------------
model ApiKey {
  id          String   @id @default(uuid(7)) @db.Uuid
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  lastUsedAt  DateTime? @db.Timestamptz(6)
  expiresAt   DateTime? @db.Timestamptz(6)
  name        String   @db.VarChar(80)
  keyPrefix   String   @db.VarChar(16)
  keyHash     String   @unique @db.VarChar(128)
  userId      String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        UserRole @default(USER)
  tier        SubscriptionTier @default(FREE)
  scopes      Json?    @db.JsonB
  enabled     Boolean  @default(true)
  deletedAt   DateTime? @db.Timestamptz(6)

  @@index([userId])
  @@index([keyPrefix])
}

// ---------------------------------------------------------------------------
// Billing Address  (one-to-one with User)
// ---------------------------------------------------------------------------
model BillingAddress {
  id        String  @id @default(uuid(7)) @db.Uuid
  userId    String  @unique @db.Uuid
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String?
  street    String?
  city      String?
  state     String?
  country   String?
  zipCode   String?
  vatNumber String?
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

// ---------------------------------------------------------------------------
// Observability  (AuditLog: queryable + ES-exportable; OutboxEvent: broker relay)
// ---------------------------------------------------------------------------
model AuditLog {
  id             String        @id @default(uuid(7)) @db.Uuid
  actorId        String?       @db.Uuid
  actor          User?         @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  organizationId String?       @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  action         AuditAction
  level          LogLevel      @default(INFO)
  entityType     String
  entityId       String?
  summary        String?
  before         Json?         @db.JsonB
  after          Json?         @db.JsonB
  ip             String?       @db.Inet
  userAgent      String?       @db.Text
  requestId      String?
  correlationId  String?
  createdAt      DateTime      @default(now()) @db.Timestamptz(6)

  @@index([actorId])
  @@index([organizationId])
  @@index([entityType, entityId])
  @@index([action, createdAt])
  @@index([correlationId])
}

model OutboxEvent {
  id            String       @id @default(uuid(7)) @db.Uuid
  aggregateType String
  aggregateId   String
  eventType     String
  payload       Json         @db.JsonB
  headers       Json?        @db.JsonB
  status        OutboxStatus @default(PENDING)
  attempts      Int          @default(0)
  lastError     String?      @db.Text
  availableAt   DateTime     @default(now()) @db.Timestamptz(6)
  publishedAt   DateTime?    @db.Timestamptz(6)
  createdAt     DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @db.Timestamptz(6)

  @@index([status, availableAt])
  @@index([aggregateType, aggregateId])
  @@index([status, updatedAt])
  @@index([createdAt])
}
