{
  "moduleFileExtensions": ["js", "mjs", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "setupFiles": ["<rootDir>/setup-e2e.ts"],
  "testRegex": "broker-.*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.m?[tj]s$": [
      "ts-jest",
      { "isolatedModules": true, "tsconfig": { "allowJs": true } }
    ]
  },
  "transformIgnorePatterns": ["/node_modules/"],
  "maxWorkers": 1,
  "testTimeout": 30000,
  "forceExit": true
}
