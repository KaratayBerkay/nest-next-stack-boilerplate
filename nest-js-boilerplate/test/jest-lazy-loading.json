{
  "moduleFileExtensions": ["js", "mjs", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "src/lazy-loading/lazy-loading\\.spec\\.ts$",
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "transform": {
    "^.+\\.m?[tj]s$": [
      "ts-jest",
      {
        "isolatedModules": true,
        "tsconfig": {
          "allowJs": true,
          "module": "commonjs",
          "moduleResolution": "node10",
          "resolvePackageJsonExports": false
        }
      }
    ]
  },
  "transformIgnorePatterns": [
    "/node_modules/(?!.*(prisma-graphql-type-decimal|otplib|@otplib|@scure|@noble))"
  ]
}
