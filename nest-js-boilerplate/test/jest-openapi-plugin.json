{
  "moduleFileExtensions": ["js", "mjs", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "setupFiles": ["<rootDir>/setup-e2e.ts"],
  "testRegex": "openapi-plugin.e2e-spec.ts$",
  "transform": {
    "^.+\\.m?[tj]s$": [
      "ts-jest",
      {
        "tsconfig": { "allowJs": true },
        "astTransformers": {
          "before": ["<rootDir>/openapi-plugin.transformer.js"]
        }
      }
    ]
  },
  "transformIgnorePatterns": [
    "/node_modules/(?!.*(prisma-graphql-type-decimal|otplib|@otplib|@scure|@noble))"
  ],
  "maxWorkers": 1,
  "forceExit": true
}
