# compiled output
/dist
/dist2
/node_modules
/build

# Logs
logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store

# Tests
/coverage
/.nyc_output

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/*
!.vscode/extensions.json

# dotenv environment variable files — real env files stay local; *.example are tracked.
.env
.env.*
*.env
!.env.example
!.env.*.example
!*.env.example

# temp directories
.temp
.tmp

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Prisma generated artifacts (client lives in node_modules by default)
prisma/*.db
prisma/migrations/dev.db*

# Generated by prisma-nestjs-graphql + GraphQL code-first (regenerate via `pnpm generate`)
/src/@generated
/src/schema.gql

# Documentation & markdown kept local (per request) — keeps the repo code-focused.
# Note: .claude/ tooling markdown (agents/skills) is intentionally still tracked.
/*.md
docs/
dist_old
