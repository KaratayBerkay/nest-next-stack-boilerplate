{
  "name": "next-js-boilerplate-",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 3001",
    "prebuild": "pnpm generate-i18n-types && pnpm fallow-check",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate-i18n-types": "tsx scripts/generate-i18n-types.ts",
    "check-duplicate-messages": "tsx scripts/check-duplicate-messages.ts",
    "fallow-check": "fallow audit --ci --fail-on-issues",
    "fallow-fix": "fallow fix --yes",
    "prepare": "husky"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@radix-ui/react-accordion": "^1.2.15",
    "@radix-ui/react-alert-dialog": "^1.1.18",
    "@radix-ui/react-aspect-ratio": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.15",
    "@radix-ui/react-context-menu": "^2.3.2",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-hover-card": "^1.1.18",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-menubar": "^1.1.19",
    "@radix-ui/react-navigation-menu": "^1.2.17",
    "@radix-ui/react-progress": "^1.1.11",
    "@radix-ui/react-radio-group": "^1.4.2",
    "@radix-ui/react-scroll-area": "^1.2.13",
    "@radix-ui/react-slider": "^1.4.2",
    "@radix-ui/react-toggle": "^1.1.13",
    "@radix-ui/react-toggle-group": "^1.1.14",
    "@stripe/react-stripe-js": "^6.7.0",
    "@stripe/stripe-js": "^9.9.0",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-form-nextjs": "^1.33.0",
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/otel": "^2.1.3",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "kafkajs": "^2.2.4",
    "next": "16.2.9",
    "pino": "^10.3.1",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "react-resizable-panels": "^4.12.1",
    "recharts": "^3.9.2",
    "server-only": "^0.0.1",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@opentelemetry/sdk-trace-base": "2.8.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "fallow": "^3.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
